rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isOrganizer(eventId) {
      return request.auth != null
        && get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }

    match /events/{eventId} {
      allow get: if true;
      allow list: if request.auth != null && resource.data.organizerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.organizerId == request.auth.uid;
      allow update: if isOrganizer(eventId);

      match /participants/{participantId} {
        allow create: if true;
        allow read, update: if isOrganizer(eventId);
      }

      match /activityLog/{logId} {
        allow create: if true;
        allow read: if isOrganizer(eventId);
      }
    }
  }
}
